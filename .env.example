# ── Server ────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql://creatrbase:PASSWORD@localhost:5432/creatrbase

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379

# ── Auth ──────────────────────────────────────────────────
SESSION_SECRET=change-me-to-a-long-random-string

# Google OAuth (used for login, Gmail, and YouTube platform connection)
# GOOGLE_LOGIN_CLIENT_ID is a legacy alias — GOOGLE_CLIENT_ID is preferred
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://creatrbase.com/auth/google/callback

# Twitch OAuth (login)
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_CALLBACK_URL=https://creatrbase.com/auth/twitch/callback

# ── YouTube Data API ──────────────────────────────────────
YOUTUBE_API_KEY=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# ── Twitch Helix API ──────────────────────────────────────
# (reuses TWITCH_CLIENT_ID / TWITCH_CLIENT_SECRET above)

# ── Anthropic ─────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Stripe ────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_CORE_MONTHLY=
STRIPE_PRICE_ID_PRO_MONTHLY=

# ── Resend (email) ────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=noreply@creatrbase.com

# ── Error tracking (Sentry) ───────────────────────────────
# Leave blank to disable. Get your DSN from sentry.io.
SENTRY_DSN=
VITE_SENTRY_DSN=

# ── Encryption ────────────────────────────────────────────
# AES-256-GCM key for encrypting OAuth tokens at rest (32-byte hex string)
ENCRYPTION_KEY=
