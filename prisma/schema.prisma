// ─── Prisma schema ────────────────────────────────────────────────────────────
// We use our own SQL migration runner (scripts/migrate.js).
// Prisma is used for the client only — do NOT use `prisma migrate`.
//
// To regenerate the client after schema changes: npx prisma generate
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Tenants ──────────────────────────────────────────────────────────────────

model Tenant {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  status      String    @default("active")
  suspendedAt DateTime? @map("suspended_at") @db.Timestamptz(6)
  suspendedBy String?   @map("suspended_by")
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletedBy   String?   @map("deleted_by")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  users                   User[]
  sessions                Session[]
  creators                Creator[]
  creatorPlatformProfiles CreatorPlatformProfile[]
  platformMetricsSnapshots PlatformMetricsSnapshot[]
  subscriptions           Subscription[]
  contentAnalysisRuns        ContentAnalysisRun[]
  creatorNicheProfiles       CreatorNicheProfile[]
  creatorCommercialProfiles  CreatorCommercialProfile[]
  dimensionScoreHistories    DimensionScoreHistory[]
  creatorMilestones          CreatorMilestone[]

  @@map("tenants")
}

// ─── Users ────────────────────────────────────────────────────────────────────

model User {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String    @map("tenant_id") @db.Uuid
  email            String    @unique
  passwordHash     String?   @map("password_hash")
  emailVerified    Boolean   @default(false) @map("email_verified")
  emailVerifiedAt  DateTime? @map("email_verified_at") @db.Timestamptz(6)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  authProviders AuthProvider[]
  sessions      Session[]
  creator       Creator?

  @@map("users")
}

// ─── Auth providers ───────────────────────────────────────────────────────────

model AuthProvider {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  provider   String
  providerId String?  @map("provider_id")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
  @@map("auth_providers")
}

// ─── Sessions ─────────────────────────────────────────────────────────────────

model Session {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  lastActive DateTime @default(now()) @map("last_active") @db.Timestamptz(6)
  expiresAt  DateTime @map("expires_at") @db.Timestamptz(6)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// ─── Creators ─────────────────────────────────────────────────────────────────

model Creator {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId              String    @map("tenant_id") @db.Uuid
  userId                String    @unique @map("user_id") @db.Uuid
  displayName           String    @map("display_name")
  onboardingStep        String    @default("account_created") @map("onboarding_step")
  onboardingCompletedAt DateTime? @map("onboarding_completed_at") @db.Timestamptz(6)
  firstInsightShownAt   DateTime? @map("first_insight_shown_at") @db.Timestamptz(6)
  firstActionAcceptedAt DateTime? @map("first_action_accepted_at") @db.Timestamptz(6)
  digestSendDay         Int       @default(1) @map("digest_send_day")
  digestSendTime        DateTime  @default(dbgenerated("'08:00:00'::time")) @map("digest_send_time") @db.Time(6)
  analysisMode          String    @default("automatic") @map("analysis_mode")
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant           Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user             User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  platformProfiles CreatorPlatformProfile[]

  @@map("creators")
}

// ─── Creator platform profiles ────────────────────────────────────────────────

model CreatorPlatformProfile {
  id                       String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId                 String    @map("tenant_id") @db.Uuid
  creatorId                String    @map("creator_id") @db.Uuid
  platform                 String
  platformUserId           String    @map("platform_user_id")
  platformUsername         String?   @map("platform_username")
  platformDisplayName      String?   @map("platform_display_name")
  platformUrl              String?   @map("platform_url")
  connectedAt              DateTime  @default(now()) @map("connected_at") @db.Timestamptz(6)
  lastSyncedAt             DateTime? @map("last_synced_at") @db.Timestamptz(6)
  syncStatus               String    @default("active") @map("sync_status")
  accessToken              String    @map("access_token")
  refreshToken             String?   @map("refresh_token")
  tokenExpiresAt           DateTime? @map("token_expires_at") @db.Timestamptz(6)
  scopesGranted            String[]  @map("scopes_granted")
  subscriberCount          Int?      @map("subscriber_count")
  totalViewCount           BigInt?   @map("total_view_count")
  videoCount               Int?      @map("video_count")
  avgViewsPerVideo30d      Decimal?  @map("avg_views_per_video_30d") @db.Decimal(10, 2)
  engagementRate30d        Decimal?  @map("engagement_rate_30d") @db.Decimal(5, 4)
  watchHours12mo           Decimal?  @map("watch_hours_12mo") @db.Decimal(10, 2)
  shortsViews90d           BigInt?   @map("shorts_views_90d")
  publicUploads90d         Int?      @map("public_uploads_90d")
  analyticsLastSyncedAt    DateTime? @map("analytics_last_synced_at") @db.Timestamptz(6)
  avgConcurrentViewers30d  Decimal?  @map("avg_concurrent_viewers_30d") @db.Decimal(6, 2)
  streamHours30d           Decimal?  @map("stream_hours_30d") @db.Decimal(8, 2)
  uniqueBroadcastDays30d   Int?      @map("unique_broadcast_days_30d")
  primaryAudienceGeo       String?   @map("primary_audience_geo")
  secondaryAudienceGeo     String?   @map("secondary_audience_geo")
  audienceAgeRange         String?   @map("audience_age_range")
  audienceGenderSkew       String?   @map("audience_gender_skew")
  yppStatus                String?   @map("ypp_status")
  twitchAffiliate          Boolean?  @map("twitch_affiliate")
  twitchPartner            Boolean?  @map("twitch_partner")
  pubsubTopic              String?   @map("pubsub_topic")
  pubsubSubscribedAt       DateTime? @map("pubsub_subscribed_at") @db.Timestamptz(6)
  pubsubExpiresAt          DateTime? @map("pubsub_expires_at") @db.Timestamptz(6)
  createdAt                DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant              Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  creator             Creator                   @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  snapshots           PlatformMetricsSnapshot[]
  contentAnalysisRuns ContentAnalysisRun[]

  @@unique([creatorId, platform])
  @@unique([platform, platformUserId])
  @@map("creator_platform_profiles")
}

// ─── Platform metrics snapshots ───────────────────────────────────────────────

model PlatformMetricsSnapshot {
  id                      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId                String   @map("tenant_id") @db.Uuid
  platformProfileId       String   @map("platform_profile_id") @db.Uuid
  platform                String
  subscriberCount         Int?     @map("subscriber_count")
  watchHours12mo          Decimal? @map("watch_hours_12mo") @db.Decimal(10, 2)
  totalViewCount          BigInt?  @map("total_view_count")
  videoCount              Int?     @map("video_count")
  avgConcurrentViewers30d Decimal? @map("avg_concurrent_viewers_30d") @db.Decimal(6, 2)
  recordedAt              DateTime @default(now()) @map("recorded_at") @db.Timestamptz(6)

  tenant          Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  platformProfile CreatorPlatformProfile @relation(fields: [platformProfileId], references: [id], onDelete: Cascade)

  @@map("platform_metrics_snapshots")
}

// ─── Subscription plans ───────────────────────────────────────────────────────

model SubscriptionPlan {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                 String
  stripePriceIdMonthly String   @map("stripe_price_id_monthly")
  stripePriceIdAnnual  String?  @map("stripe_price_id_annual")
  amountMonthly        Int      @map("amount_monthly")
  amountAnnual         Int?     @map("amount_annual")
  currency             String
  analysisRunsPerWeek  Int      @map("analysis_runs_per_week")
  features             Json
  isActive             Boolean  @default(true) @map("is_active")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  subscriptions Subscription[]

  @@unique([name, currency])
  @@map("subscription_plans")
}

// ─── Subscriptions ────────────────────────────────────────────────────────────

model Subscription {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId             String    @unique @map("tenant_id") @db.Uuid
  planId               String    @map("plan_id") @db.Uuid
  stripeSubscriptionId String?   @map("stripe_subscription_id")
  stripeCustomerId     String    @map("stripe_customer_id")
  status               String    @default("trialling")
  billingInterval      String    @default("month") @map("billing_interval")
  trialStart           DateTime? @map("trial_start") @db.Timestamptz(6)
  trialEnd             DateTime? @map("trial_end") @db.Timestamptz(6)
  trialWarningSent     Boolean   @default(false) @map("trial_warning_sent")
  currentPeriodStart   DateTime? @map("current_period_start") @db.Timestamptz(6)
  currentPeriodEnd     DateTime? @map("current_period_end") @db.Timestamptz(6)
  cancelAtPeriodEnd    Boolean   @default(false) @map("cancel_at_period_end")
  cancelledAt          DateTime? @map("cancelled_at") @db.Timestamptz(6)
  cancellationReason   String?   @map("cancellation_reason")
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan   SubscriptionPlan @relation(fields: [planId], references: [id])

  @@map("subscriptions")
}

// ─── Content analysis runs ───────────────────────────────────────────────────
// Created in migration 002. Migration 013 added platform_profile_id + tokens_used.

model ContentAnalysisRun {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId            String    @map("tenant_id") @db.Uuid
  creatorId           String    @map("creator_id") @db.Uuid
  platformProfileId   String?   @map("platform_profile_id") @db.Uuid
  platform            String
  runType             String    @default("baseline") @map("run_type")
  triggeredBy         String    @default("system_onboarding") @map("triggered_by")
  runStatus           String    @default("queued") @map("run_status")
  videosSampled       Int?      @map("videos_sampled")
  videoIdsSampled     String[]  @map("video_ids_sampled")
  signalsExtracted    Json?     @map("signals_extracted")
  claudePromptVersion String?   @map("claude_prompt_version")
  claudeRawOutput     Json?     @map("claude_raw_output")
  classificationOutput Json?    @map("classification_output")
  confidenceScore     Int?      @map("confidence_score")
  errorDetails        String?   @map("error_details") @db.Text
  tokensUsed          Int?      @map("tokens_used")
  startedAt           DateTime? @map("started_at") @db.Timestamptz(6)
  completedAt         DateTime? @map("completed_at") @db.Timestamptz(6)
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant          Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  platformProfile CreatorPlatformProfile? @relation(fields: [platformProfileId], references: [id], onDelete: Cascade)

  @@map("content_analysis_runs")
}

// ─── Creator niche profiles ───────────────────────────────────────────────────
// Created in migration 002. Migration 013 added brand_mentions + reasoning fields.
// UNIQUE(creator_id, platform) — one profile per creator per platform.
// brands_mentioned UUID[] is omitted here (references brand registry, not used by worker).

model CreatorNicheProfile {
  id                         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId                   String    @map("tenant_id") @db.Uuid
  creatorId                  String    @map("creator_id") @db.Uuid
  platform                   String
  primaryNicheCategory       String?   @map("primary_niche_category")
  primaryNicheSpecific       String?   @map("primary_niche_specific")
  secondaryNicheSpecific     String?   @map("secondary_niche_specific")
  contentFormatPrimary       String?   @map("content_format_primary")
  contentFormatSecondary     String?   @map("content_format_secondary")
  affiliateDomainsDetected   String[]  @map("affiliate_domains_detected")
  promoCodesDetected         String[]  @map("promo_codes_detected")
  brandMentions              String[]  @map("brand_mentions")
  existingPartnerships       Boolean   @default(false) @map("existing_partnerships")
  classificationConfidence   String    @default("low") @map("classification_confidence")
  classificationMethod       String    @default("baseline_run") @map("classification_method")
  userConfirmed              Boolean   @default(false) @map("user_confirmed")
  userConfirmedAt            DateTime? @map("user_confirmed_at") @db.Timestamptz(6)
  confidenceReasoning        String?   @map("confidence_reasoning") @db.Text
  nicheCommercialNotes       String?   @map("niche_commercial_notes") @db.Text
  classificationReasoning    String?   @map("classification_reasoning") @db.Text
  baselineRunId              String?   @map("baseline_run_id") @db.Uuid
  lastRefinedAt              DateTime? @map("last_refined_at") @db.Timestamptz(6)
  createdAt                  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                  DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([creatorId, platform])
  @@map("creator_niche_profiles")
}

// ─── Creator commercial profiles ─────────────────────────────────────────────
// Created in migration 002. One row per creator. Updated by viability scoring worker.

model CreatorCommercialProfile {
  id                       String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId                 String    @unique @map("tenant_id") @db.Uuid
  creatorId                String    @unique @map("creator_id") @db.Uuid
  commercialViabilityScore Int?      @map("commercial_viability_score")
  viabilityScoreConfidence String?   @map("viability_score_confidence")
  viabilityLastCalculated  DateTime? @map("viability_last_calculated") @db.Timestamptz(6)
  viabilityBreakdown       Json?     @map("viability_breakdown")
  commercialTier           String?   @map("commercial_tier")
  gapToNextTier            Json?     @map("gap_to_next_tier")
  gapPrimaryConstraint     String?   @map("gap_primary_constraint")
  projectedTierUpgradeDate DateTime? @map("projected_tier_upgrade_date") @db.Date
  estimatedRateLow         Int?      @map("estimated_rate_low")
  estimatedRateHigh        Int?      @map("estimated_rate_high")
  rateCurrency             String?   @map("rate_currency")
  rateConfidence           String?   @map("rate_confidence")
  rateLastCalculated       DateTime? @map("rate_last_calculated") @db.Timestamptz(6)
  confirmedDealsCount      Int       @default(0) @map("confirmed_deals_count")
  confirmedEarningsTotal   Int       @default(0) @map("confirmed_earnings_total")
  confirmedEarnings12mo    Int       @default(0) @map("confirmed_earnings_12mo")
  lastDealDate             DateTime? @map("last_deal_date") @db.Date
  avgPostsPerWeek          Decimal?  @map("avg_posts_per_week") @db.Decimal(4, 2)
  postingConsistencyScore  Int?      @map("posting_consistency_score")
  lastPostedAt             DateTime? @map("last_posted_at") @db.Timestamptz(6)
  createdAt                DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("creator_commercial_profiles")
}

// ─── Dimension score history ──────────────────────────────────────────────────
// Append-only time-series. Powers the progress chart.

model DimensionScoreHistory {
  id                         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId                   String   @map("tenant_id") @db.Uuid
  creatorId                  String   @map("creator_id") @db.Uuid
  scoredAt                   DateTime @default(now()) @map("scored_at") @db.Timestamptz(6)
  triggerType                String   @map("trigger_type")
  subscriberMomentumScore    Int?     @map("subscriber_momentum_score")
  subscriberMomentumConf     String?  @map("subscriber_momentum_conf")
  engagementQualityScore     Int?     @map("engagement_quality_score")
  engagementQualityConf      String?  @map("engagement_quality_conf")
  nicheCommercialValueScore  Int?     @map("niche_commercial_value_score")
  nicheCommercialValueConf   String?  @map("niche_commercial_value_conf")
  audienceGeoAlignmentScore  Int?     @map("audience_geo_alignment_score")
  audienceGeoAlignmentConf   String?  @map("audience_geo_alignment_conf")
  contentConsistencyScore    Int?     @map("content_consistency_score")
  contentConsistencyConf     String?  @map("content_consistency_conf")
  contentBrandAlignmentScore Int?     @map("content_brand_alignment_score")
  contentBrandAlignmentConf  String?  @map("content_brand_alignment_conf")
  overallScore               Int?     @map("overall_score")
  commercialTier             String?  @map("commercial_tier")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("dimension_score_history")
}

// ─── Creator milestones ───────────────────────────────────────────────────────
// One row per milestone per creator. Upserted by viability scoring worker.

model CreatorMilestone {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId             String    @map("tenant_id") @db.Uuid
  creatorId            String    @map("creator_id") @db.Uuid
  milestoneType        String    @map("milestone_type")
  status               String    @default("not_started") @map("status")
  approachingThreshold Decimal?  @map("approaching_threshold") @db.Decimal(5, 2)
  crossedAt            DateTime? @map("crossed_at") @db.Timestamptz(6)
  crossingMetric       String?   @map("crossing_metric")
  crossingMetricValue  String?   @map("crossing_metric_value")
  thresholdSnapshot    Json?     @map("threshold_snapshot")
  capabilitiesUnlocked String[]  @map("capabilities_unlocked")
  firstShownAt         DateTime? @map("first_shown_at") @db.Timestamptz(6)
  notificationSentAt   DateTime? @map("notification_sent_at") @db.Timestamptz(6)
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([creatorId, milestoneType])
  @@map("creator_milestones")
}

// ─── Billing events ───────────────────────────────────────────────────────────

model BillingEvent {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  stripeEventId String    @unique @map("stripe_event_id")
  eventType     String    @map("event_type")
  payload       Json
  processed     Boolean   @default(false)
  processedAt   DateTime? @map("processed_at") @db.Timestamptz(6)
  error         String?
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("billing_events")
}
